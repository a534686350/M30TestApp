<Window x:Class="M30TestApp.Wpf.Views.UpdateProgressWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="正在更新"
        Width="460"
        SizeToContent="Height"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner"
        ShowInTaskbar="False"
        Topmost="True"
        Background="{DynamicResource SurfaceBrush}">
    <Border Padding="26" Background="{DynamicResource SurfaceBrush}">
        <StackPanel>
            <TextBlock Text="正在更新程序"
                       FontSize="20"
                       FontWeight="Bold"
                       Foreground="{DynamicResource AccentBrush}"
                       HorizontalAlignment="Center"
                       Margin="0,0,0,8"/>

            <TextBlock Text="更新过程中程序暂时不可使用，请等待完成。"
                       FontSize="12"
                       Foreground="{DynamicResource MutedBrush}"
                       TextAlignment="Center"
                       TextWrapping="Wrap"
                       HorizontalAlignment="Center"
                       Margin="0,0,0,18"/>

            <TextBlock x:Name="StatusText"
                       Text="准备下载更新..."
                       FontSize="13"
                       FontWeight="SemiBold"
                       TextWrapping="Wrap"
                       TextAlignment="Center"
                       HorizontalAlignment="Center"
                       Margin="0,0,0,10"/>

            <ProgressBar x:Name="Progress"
                         Minimum="0"
                         Maximum="100"
                         Height="14"
                         Value="0"
                         IsIndeterminate="True"
                         Margin="0,0,0,8"/>

            <TextBlock x:Name="PercentText"
                       Text=""
                       FontSize="12"
                       Foreground="{DynamicResource MutedBrush}"
                       HorizontalAlignment="Center"/>
        </StackPanel>
    </Border>
</Window>
