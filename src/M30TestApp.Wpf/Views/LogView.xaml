<UserControl x:Class="M30TestApp.Wpf.Views.LogView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:M30TestApp.Wpf.ViewModels"
             d:DataContext="{d:DesignInstance vm:LogViewModel}"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             mc:Ignorable="d">

    <Grid Margin="12">
        <Border Style="{StaticResource Card}" Padding="0">
            <DockPanel>
                <Border DockPanel.Dock="Top" Background="{StaticResource HeaderBgBrush}"
                        BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,0,0,1"
                        Padding="12,8">
                    <DockPanel>
                        <TextBlock Text="运行日志" FontWeight="SemiBold" VerticalAlignment="Center"/>
                        <Button DockPanel.Dock="Right" Content="清空" Style="{StaticResource GhostButton}"
                                Command="{Binding ClearCommand}" HorizontalAlignment="Right"/>
                    </DockPanel>
                </Border>
                <TextBox Text="{Binding LogText, Mode=OneWay}" BorderThickness="0"
                         FontFamily="Consolas" FontSize="12"
                         Background="{StaticResource SurfaceBrush}"
                         IsReadOnly="True" AcceptsReturn="True" AcceptsTab="True"
                         TextWrapping="NoWrap"
                         VerticalScrollBarVisibility="Auto"
                         HorizontalScrollBarVisibility="Auto"
                         Padding="10,4"/>
            </DockPanel>
        </Border>
    </Grid>
</UserControl>
