<UserControl x:Class="M30TestApp.Wpf.Views.ManualView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:M30TestApp.Wpf.ViewModels"
             d:DataContext="{d:DesignInstance vm:ManualViewModel}"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             mc:Ignorable="d">

    <UserControl.Resources>
        <Style x:Key="Lbl" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource MutedBrush}"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="Margin" Value="0,0,0,2"/>
        </Style>
        <Style x:Key="GroupTitle" TargetType="TextBlock">
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Margin" Value="0,0,0,8"/>
        </Style>
        <Style x:Key="OutBox" TargetType="TextBox">
            <Setter Property="IsReadOnly" Value="True"/>
            <Setter Property="Background"  Value="{StaticResource SurfaceBrush}"/>
            <Setter Property="FontFamily"  Value="Consolas"/>
            <Setter Property="Width"       Value="100"/>
            <Setter Property="HorizontalAlignment" Value="Left"/>
        </Style>
        <Style x:Key="ReadButton" TargetType="Button" BasedOn="{StaticResource GhostButton}">
            <Setter Property="Padding" Value="10,3"/>
            <Setter Property="MinWidth" Value="120"/>
            <Setter Property="Margin" Value="0,0,8,0"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
        </Style>
        <Style x:Key="ActionButton" TargetType="Button" BasedOn="{StaticResource PrimaryButton}">
            <Setter Property="Padding" Value="10,4"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="Margin" Value="0,0,0,6"/>
            <Setter Property="HorizontalAlignment" Value="Stretch"/>
        </Style>
        <Style x:Key="MutedActionButton" TargetType="Button" BasedOn="{StaticResource GhostButton}">
            <Setter Property="Padding" Value="10,4"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="Margin" Value="0,0,0,6"/>
            <Setter Property="HorizontalAlignment" Value="Stretch"/>
        </Style>
    </UserControl.Resources>

    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="180"/>
        </Grid.RowDefinitions>

        <ScrollViewer Grid.Row="0" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
        <StackPanel>

        <!-- ════════════════════════════════════════════════════════ -->
        <!-- Row 0: 串口设置 + 通道选择 + 读取数据                   -->
        <!-- ════════════════════════════════════════════════════════ -->
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="290"/>
                <ColumnDefinition Width="290"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- 采集卡串口 -->
            <Border Style="{StaticResource Card}" Grid.Column="0" Margin="0,0,8,8">
                <StackPanel>
                    <TextBlock Text="数据采集卡串口设置" Style="{StaticResource GroupTitle}"/>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        <Grid Grid.Row="0" Grid.Column="0" Margin="0,0,4,6">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="串口号" Style="{StaticResource Lbl}"/>
                            <ComboBox Grid.Column="0" Margin="0,18,4,0"
                                      ItemsSource="{Binding ComPorts}"
                                      Text="{Binding CardCom, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                      IsEditable="True"/>
                            <Button Grid.Column="1" Margin="0,18,0,0" Padding="8,0"
                                    Content="刷新" Command="{Binding RefreshComPortsCommand}"/>
                        </Grid>
                        <StackPanel Grid.Row="0" Grid.Column="1" Margin="4,0,0,6">
                            <TextBlock Text="校验位" Style="{StaticResource Lbl}"/>
                            <ComboBox ItemsSource="{Binding ParityList}" SelectedItem="{Binding CardParity}"/>
                        </StackPanel>
                        <StackPanel Grid.Row="1" Grid.Column="0" Margin="0,0,4,6">
                            <TextBlock Text="波特率" Style="{StaticResource Lbl}"/>
                            <ComboBox ItemsSource="{Binding BaudRates}" SelectedItem="{Binding CardBaud}"/>
                        </StackPanel>
                        <StackPanel Grid.Row="1" Grid.Column="1" Margin="4,0,0,6">
                            <TextBlock Text="停止位" Style="{StaticResource Lbl}"/>
                            <ComboBox ItemsSource="{Binding StopBits}" SelectedItem="{Binding CardStop}"/>
                        </StackPanel>
                        <StackPanel Grid.Row="2" Grid.Column="0" Margin="0,0,4,0">
                            <TextBlock Text="数据位" Style="{StaticResource Lbl}"/>
                            <ComboBox ItemsSource="{Binding DataBits}" SelectedItem="{Binding CardData}"/>
                        </StackPanel>
                        <Button Grid.Row="2" Grid.Column="1" Margin="4,0,0,0" VerticalAlignment="Bottom"
                                Content="{Binding CardSerialButtonText}" Style="{StaticResource ActionButton}"
                                Command="{Binding OpenCardSerialCommand}"/>
                    </Grid>
                    <TextBlock Text="{Binding CardSerialStatusText}" Foreground="{StaticResource MutedBrush}" Margin="0,6,0,0"/>
                </StackPanel>
            </Border>

            <!-- 烘箱串口 -->
            <Border Style="{StaticResource Card}" Grid.Column="1" Margin="0,0,8,8">
                <StackPanel>
                    <TextBlock Text="烘箱串口设置" Style="{StaticResource GroupTitle}"/>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        <Grid Grid.Row="0" Grid.Column="0" Margin="0,0,4,6">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="串口号" Style="{StaticResource Lbl}"/>
                            <ComboBox Grid.Column="0" Margin="0,18,4,0"
                                      ItemsSource="{Binding ComPorts}"
                                      Text="{Binding OvenCom, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                      IsEditable="True"/>
                            <Button Grid.Column="1" Margin="0,18,0,0" Padding="8,0"
                                    Content="刷新" Command="{Binding RefreshComPortsCommand}"/>
                        </Grid>
                        <StackPanel Grid.Row="0" Grid.Column="1" Margin="4,0,0,6">
                            <TextBlock Text="校验位" Style="{StaticResource Lbl}"/>
                            <ComboBox ItemsSource="{Binding ParityList}" SelectedItem="{Binding OvenParity}"/>
                        </StackPanel>
                        <StackPanel Grid.Row="1" Grid.Column="0" Margin="0,0,4,6">
                            <TextBlock Text="波特率" Style="{StaticResource Lbl}"/>
                            <ComboBox ItemsSource="{Binding BaudRates}" SelectedItem="{Binding OvenBaud}"/>
                        </StackPanel>
                        <StackPanel Grid.Row="1" Grid.Column="1" Margin="4,0,0,6">
                            <TextBlock Text="停止位" Style="{StaticResource Lbl}"/>
                            <ComboBox ItemsSource="{Binding StopBits}" SelectedItem="{Binding OvenStop}"/>
                        </StackPanel>
                        <StackPanel Grid.Row="2" Grid.Column="0" Margin="0,0,4,0">
                            <TextBlock Text="数据位" Style="{StaticResource Lbl}"/>
                            <ComboBox ItemsSource="{Binding DataBits}" SelectedItem="{Binding OvenData}"/>
                        </StackPanel>
                        <Button Grid.Row="2" Grid.Column="1" Margin="4,0,0,0" VerticalAlignment="Bottom"
                                Content="{Binding OvenSerialButtonText}" Style="{StaticResource ActionButton}"
                                Command="{Binding OpenOvenSerialCommand}"/>
                    </Grid>
                    <TextBlock Text="{Binding OvenSerialStatusText}" Foreground="{StaticResource MutedBrush}" Margin="0,6,0,0"/>
                </StackPanel>
            </Border>

            <!-- 读取数据 -->
            <Border Style="{StaticResource Card}" Grid.Column="2" Margin="0,0,0,8">
                <StackPanel>
                    <TextBlock Text="通道选择" Style="{StaticResource GroupTitle}"/>
                    <Grid Margin="0,0,0,8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="150"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Margin="0,0,4,0">
                            <TextBlock Text="工位" Style="{StaticResource Lbl}"/>
                            <TextBox Text="{Binding SelectedSlot, UpdateSourceTrigger=PropertyChanged}"/>
                        </StackPanel>
                        <StackPanel Grid.Column="1" Margin="4,0,4,0">
                            <TextBlock Text="采集卡地址" Style="{StaticResource Lbl}"/>
                            <ComboBox ItemsSource="{Binding CardAddrs}" SelectedItem="{Binding CardAddr}"/>
                        </StackPanel>
                        <StackPanel Grid.Column="2" Margin="4,0,0,0">
                            <TextBlock Text="通道地址" Style="{StaticResource Lbl}"/>
                            <ComboBox ItemsSource="{Binding ChannelAddrs}" SelectedItem="{Binding ChannelAddr}"/>
                        </StackPanel>
                        <StackPanel Grid.Column="3" Margin="10,0,0,0">
                            <TextBlock Text="{Binding UtPowerText}" Style="{StaticResource Lbl}"/>
                            <Button Content="⇄ 切换 UT 电源" Style="{StaticResource ActionButton}"
                                    Command="{Binding SwitchUtPowerCommand}"/>
                        </StackPanel>
                    </Grid>
                    <Separator Margin="0,0,0,6"/>
                    <TextBlock Text="读取数据" Style="{StaticResource GroupTitle}"/>
                    <Grid HorizontalAlignment="Left">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="160"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <Button Grid.Row="0" Grid.Column="0" Content="🔋 读驱动电压"
                                Style="{StaticResource ReadButton}"
                                Command="{Binding ReadDriveVCommand}"/>
                        <TextBox Grid.Row="0" Grid.Column="1" Style="{StaticResource OutBox}" Text="{Binding ReadDriveV}"/>
                        <TextBlock Grid.Row="0" Grid.Column="2" Text="V" Margin="4,0,0,0"
                                   VerticalAlignment="Center" Foreground="{StaticResource MutedBrush}"/>

                        <Button Grid.Row="1" Grid.Column="0" Content="⚡ 读驱动电流"
                                Style="{StaticResource ReadButton}"
                                Command="{Binding ReadDriveICommand}" Margin="0,6,8,0"/>
                        <TextBox Grid.Row="1" Grid.Column="1" Style="{StaticResource OutBox}"
                                 Text="{Binding ReadDriveI}" Margin="0,6,0,0"/>
                        <TextBlock Grid.Row="1" Grid.Column="2" Text="mA" Margin="4,6,0,0"
                                   VerticalAlignment="Center" Foreground="{StaticResource MutedBrush}"/>

                        <Button Grid.Row="2" Grid.Column="0" Content="📡 读 Usig"
                                Style="{StaticResource ReadButton}"
                                Command="{Binding ReadUsigCommand}" Margin="0,6,8,0"/>
                        <TextBox Grid.Row="2" Grid.Column="1" Style="{StaticResource OutBox}"
                                 Text="{Binding ReadUsig}" Margin="0,6,0,0"/>
                        <TextBlock Grid.Row="2" Grid.Column="2" Text="mV" Margin="4,6,0,0"
                                   VerticalAlignment="Center" Foreground="{StaticResource MutedBrush}"/>

                        <Button Grid.Row="3" Grid.Column="0" Content="🌡 读 UT"
                                Style="{StaticResource ReadButton}"
                                Command="{Binding ReadUtCommand}" Margin="0,6,8,0"/>
                        <TextBox Grid.Row="3" Grid.Column="1" Style="{StaticResource OutBox}"
                                 Text="{Binding ReadUT}" Margin="0,6,0,0"/>
                        <TextBlock Grid.Row="3" Grid.Column="2" Text="mV" Margin="4,6,0,0"
                                   VerticalAlignment="Center" Foreground="{StaticResource MutedBrush}"/>

                        <Button Grid.Row="4" Grid.Column="0" Content="🌡 读温度变送器 (T)"
                                Style="{StaticResource ReadButton}"
                                Command="{Binding ReadTCommand}" Margin="0,6,8,0"/>
                        <TextBox Grid.Row="4" Grid.Column="1" Style="{StaticResource OutBox}"
                                 Text="{Binding ReadT}" Margin="0,6,0,0"/>
                        <TextBlock Grid.Row="4" Grid.Column="2" Text="mV" Margin="4,6,0,0"
                                   VerticalAlignment="Center" Foreground="{StaticResource MutedBrush}"/>

                        <Button Grid.Row="5" Grid.Column="0" Content="🔬 读 40uA"
                                Style="{StaticResource ReadButton}"
                                Command="{Binding Read40uACommand}" Margin="0,6,8,0"/>
                        <TextBox Grid.Row="5" Grid.Column="1" Style="{StaticResource OutBox}"
                                 Text="{Binding Read40uA}" Margin="0,6,0,0"/>
                        <TextBlock Grid.Row="5" Grid.Column="2" Text="uA" Margin="4,6,0,0"
                                   VerticalAlignment="Center" Foreground="{StaticResource MutedBrush}"/>
                    </Grid>
                </StackPanel>
            </Border>
        </Grid>

        <!-- ════════════════════════════════════════════════════════ -->
        <!-- Row 1: 通道选择 + 压控 + 烘箱温控 + 阀门控制              -->
        <!-- ════════════════════════════════════════════════════════ -->
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="290"/>
                <ColumnDefinition Width="290"/>
                <ColumnDefinition Width="220"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- 压力控制 (左) -->
            <Border Style="{StaticResource Card}" Grid.Column="0" Margin="0,0,8,0">
                <StackPanel>
                    <TextBlock Text="压力控制" Style="{StaticResource GroupTitle}"/>
                    <Grid Margin="0,0,0,8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Margin="0,0,4,0">
                            <TextBlock Text="端口" Style="{StaticResource Lbl}"/>
                            <ComboBox ItemsSource="{Binding PressurePorts}"
                                      Text="{Binding PressurePort, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                      IsEditable="True"/>
                        </StackPanel>
                        <StackPanel Grid.Column="1" Margin="4,0,0,0">
                            <TextBlock Text="地址" Style="{StaticResource Lbl}"/>
                            <ComboBox ItemsSource="{Binding PressureAddrs}"
                                      Text="{Binding PressureAddr, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                      IsEditable="True"/>
                        </StackPanel>
                    </Grid>

                    <TextBlock Text="型号" Style="{StaticResource Lbl}"/>
                    <ComboBox ItemsSource="{Binding PressureModels}"
                              Text="{Binding PressureModel, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                              IsEditable="True" Margin="0,0,0,6"/>

                    <Grid Margin="0,0,0,6">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Margin="0,0,4,0">
                            <TextBlock Text="压力单位" Style="{StaticResource Lbl}"/>
                            <ComboBox ItemsSource="{Binding PressureUnits}" SelectedItem="{Binding PressureUnit}"/>
                        </StackPanel>
                        <StackPanel Grid.Column="1" Margin="4,0,0,0">
                            <TextBlock Text="精度" Style="{StaticResource Lbl}"/>
                            <TextBox Text="{Binding Precision}"/>
                        </StackPanel>
                    </Grid>
                    <TextBlock Text="压力值" Style="{StaticResource Lbl}"/>
                    <TextBox Text="{Binding TargetPressure}" Margin="0,0,0,8"/>

                    <!-- 操作按钮 (双列) -->
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0" Margin="0,0,4,0">
                            <Button Content="📡 联接压力控制器" Style="{StaticResource ActionButton}"
                                    Command="{Binding ConnectPressureCommand}"/>
                            <Button Content="🔼 加压"            Style="{StaticResource ActionButton}"
                                    Command="{Binding SetPressureCommand}"/>
                            <Button Content="🔽 泄压"            Style="{StaticResource ActionButton}"
                                    Command="{Binding VentCommand}"/>
                            <Button Content="📏 读取量程"        Style="{StaticResource MutedActionButton}"
                                    Command="{Binding ReadRangeCommand}"/>
                            <Button Content="🎯 调零"            Style="{StaticResource MutedActionButton}"
                                    Command="{Binding ZeroCommand}"/>
                            <Button Content="🛈 读取状态"        Style="{StaticResource MutedActionButton}"
                                    Command="{Binding ReadStatusCommand}"/>
                        </StackPanel>
                        <StackPanel Grid.Column="1" Margin="4,0,0,0">
                            <Button Content="🔍 读取压力"        Style="{StaticResource MutedActionButton}"
                                    Command="{Binding ReadPressureCommand}"/>
                            <TextBox Text="{Binding ReadPressureText, Mode=OneWay}" IsReadOnly="True" Margin="0,0,0,6"
                                     FontFamily="Consolas"/>
                            <Button Content="🆔 读取型号"        Style="{StaticResource MutedActionButton}"
                                    Command="{Binding ReadModelCommand}"/>
                            <Button Content="🔄 切换测量模式"    Style="{StaticResource MutedActionButton}"
                                    Command="{Binding SwitchModeCommand}"/>
                            <Button Content="🔧 自检"            Style="{StaticResource MutedActionButton}"
                                    Command="{Binding SelfTestCommand}"/>
                        </StackPanel>
                    </Grid>

                    <!-- 手动 SCPI -->
                    <Border Background="{StaticResource HeaderBgBrush}" CornerRadius="4" Padding="8" Margin="0,8,0,0">
                        <StackPanel>
                            <TextBlock Text="手动 SCPI" Foreground="{StaticResource MutedBrush}" FontSize="11"
                                       Margin="0,0,0,4"/>
                            <TextBox Text="{Binding ManualScpi, UpdateSourceTrigger=PropertyChanged}"
                                     FontFamily="Consolas"/>
                            <Grid Margin="0,4,0,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Button Content="📤 发送指令" Style="{StaticResource MutedActionButton}" Margin="0,0,4,0"
                                        Command="{Binding SendScpiCommand}"/>
                                <Button Grid.Column="1" Content="📥 读取返回值" Style="{StaticResource MutedActionButton}" Margin="4,0,0,0"
                                        Command="{Binding ReadScpiReplyCommand}"/>
                            </Grid>
                            <TextBox Text="{Binding ManualScpiReply, Mode=OneWay}" IsReadOnly="True"
                                     FontFamily="Consolas" Margin="0,4,0,0"/>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </Border>

            <!-- 阀门控制 + 通道 + 烘箱温度 (中) -->
            <Border Style="{StaticResource Card}" Grid.Column="1" Margin="0,0,8,0">
                <StackPanel>
                    <DockPanel Margin="0,0,0,8">
                        <Button DockPanel.Dock="Right"
                                Content="刷新状态"
                                Style="{StaticResource MutedActionButton}"
                                Command="{Binding RefreshValveStatesCommand}"
                                Padding="8,3"
                                MinWidth="68"
                                Margin="0"
                                HorizontalAlignment="Right"/>
                        <TextBlock Text="阀门控制"
                                   Style="{StaticResource GroupTitle}"
                                   Margin="0,0,8,0"/>
                    </DockPanel>
                    <ItemsControl ItemsSource="{Binding Valves}">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <UniformGrid Columns="3" Rows="3"/>
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Background="{StaticResource SurfaceBrush}"
                                        BorderBrush="{StaticResource BorderBrush}" BorderThickness="1"
                                        CornerRadius="4" Margin="3" Padding="6,6">
                                    <StackPanel HorizontalAlignment="Center">
                                        <TextBlock Text="{Binding Label}" HorizontalAlignment="Center"
                                                   FontSize="11" Foreground="{StaticResource MutedBrush}"/>
                                        <ToggleButton IsChecked="{Binding IsOn}" Width="42" Height="22" Margin="0,4,0,0">
                                            <ToggleButton.Style>
                                                <Style TargetType="ToggleButton">
                                                    <Setter Property="Background" Value="{StaticResource HeaderBgBrush}"/>
                                                    <Setter Property="Foreground" Value="{StaticResource MutedBrush}"/>
                                                    <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}"/>
                                                    <Setter Property="BorderThickness" Value="1"/>
                                                    <Setter Property="Content" Value="关"/>
                                                    <Setter Property="Template">
                                                        <Setter.Value>
                                                            <ControlTemplate TargetType="ToggleButton">
                                                                <Border Background="{TemplateBinding Background}"
                                                                        BorderBrush="{TemplateBinding BorderBrush}"
                                                                        BorderThickness="{TemplateBinding BorderThickness}"
                                                                        CornerRadius="3">
                                                                    <ContentPresenter HorizontalAlignment="Center"
                                                                                      VerticalAlignment="Center"/>
                                                                </Border>
                                                            </ControlTemplate>
                                                        </Setter.Value>
                                                    </Setter>
                                                    <Style.Triggers>
                                                        <Trigger Property="IsChecked" Value="True">
                                                            <Setter Property="Background" Value="{StaticResource SuccessBrush}"/>
                                                            <Setter Property="Foreground" Value="White"/>
                                                            <Setter Property="BorderBrush" Value="{StaticResource SuccessBrush}"/>
                                                            <Setter Property="Content" Value="开"/>
                                                        </Trigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </ToggleButton.Style>
                                        </ToggleButton>
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>

                    <Separator Margin="0,10"/>

                    <TextBlock Text="烘箱温度控制" Style="{StaticResource GroupTitle}"/>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel>
                            <TextBlock Text="温度 (°C)" Style="{StaticResource Lbl}"/>
                            <TextBox Text="{Binding TargetTemp, UpdateSourceTrigger=PropertyChanged}"/>
                        </StackPanel>
                        <StackPanel Grid.Column="1" Margin="6,0,0,0" VerticalAlignment="Bottom">
                            <Button Content="🌡 设定温度" Style="{StaticResource ActionButton}"
                                    Command="{Binding SetTempCommand}" MinWidth="100"/>
                            <Button Content="停止烘箱" Style="{StaticResource MutedActionButton}"
                                    Command="{Binding StopOvenCommand}" MinWidth="100"/>
                        </StackPanel>
                    </Grid>
                    <Grid Margin="0,6,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBox Text="{Binding ReadOvenText, Mode=OneWay}" IsReadOnly="True" FontFamily="Consolas"/>
                        <Button Grid.Column="1" Margin="6,0,0,0" Content="读温" Style="{StaticResource MutedActionButton}"
                                Command="{Binding ReadOvenCommand}" MinWidth="60"/>
                    </Grid>
                </StackPanel>
            </Border>

            <!-- 多点采集 (右) -->
            <Border Style="{StaticResource Card}" Grid.Column="2" Grid.ColumnSpan="2" Margin="0">
                <StackPanel>
                    <TextBlock Text="批量采集" Style="{StaticResource GroupTitle}"/>
                    <Grid Margin="0,0,0,8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Margin="0,0,4,0">
                            <TextBlock Text="起始工位" Style="{StaticResource Lbl}"/>
                            <TextBox Text="{Binding BatchStartSlot, UpdateSourceTrigger=PropertyChanged}"/>
                        </StackPanel>
                        <StackPanel Grid.Column="1" Margin="4,0,4,0">
                            <TextBlock Text="结束工位" Style="{StaticResource Lbl}"/>
                            <TextBox Text="{Binding BatchEndSlot, UpdateSourceTrigger=PropertyChanged}"/>
                        </StackPanel>
                        <StackPanel Grid.Column="2" Margin="4,0,4,0">
                            <TextBlock Text="采集类型" Style="{StaticResource Lbl}"/>
                            <StackPanel Orientation="Horizontal">
                                <CheckBox Content="Usig" IsChecked="{Binding CollectUsig}" Margin="0,0,6,0"/>
                                <CheckBox Content="UT" IsChecked="{Binding CollectUt}" Margin="0,0,6,0"/>
                                <CheckBox Content="Usource" IsChecked="{Binding CollectUsource}" Margin="0,0,6,0"/>
                                <CheckBox Content="Isource" IsChecked="{Binding CollectIsource}"/>
                            </StackPanel>
                        </StackPanel>
                        <StackPanel Grid.Column="3" Margin="4,0,0,0">
                            <TextBlock Text="标签 (列名前缀)" Style="{StaticResource Lbl}"/>
                            <TextBox Text="{Binding ManualLabel, UpdateSourceTrigger=PropertyChanged}"/>
                        </StackPanel>
                    </Grid>
                    <Grid Margin="0,0,0,8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0" Margin="0,0,8,0">
                            <TextBlock Text="采集间隔" Style="{StaticResource Lbl}"/>
                            <TextBox Text="{Binding CollectionInterval, UpdateSourceTrigger=PropertyChanged}" Width="80"/>
                        </StackPanel>
                        <TextBlock Grid.Column="1" Text="ms" VerticalAlignment="Bottom" Margin="0,0,0,4" Foreground="{StaticResource MutedBrush}"/>
                    </Grid>
                    <Grid Margin="0,0,0,8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <Button Content="▶ 批量采集" Style="{StaticResource ActionButton}"
                                Command="{Binding BatchSampleCommand}" Margin="0,0,4,0"/>
                        <Button Grid.Column="1" Content="⏹ 停止" Style="{StaticResource MutedActionButton}"
                                Command="{Binding StopBatchSampleCommand}" Margin="4,0,4,0"/>
                        <Button Grid.Column="2" Content="📥 导出" Style="{StaticResource MutedActionButton}"
                                Command="{Binding ExportBatchResultsCommand}" Margin="0,0,0,0"/>
                    </Grid>
                    <DataGrid ItemsSource="{Binding BatchResults}" AutoGenerateColumns="False"
                              BorderThickness="0" Background="{StaticResource SurfaceBrush}"
                              GridLinesVisibility="Horizontal" HeadersVisibility="Column"
                              CanUserAddRows="False" CanUserDeleteRows="False"
                              RowBackground="Transparent" AlternatingRowBackground="{StaticResource HeaderBgBrush}"
                              Padding="0" MaxHeight="120"
                              ClipboardCopyMode="IncludeHeader">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="时间" Binding="{Binding Time}" Width="80"/>
                            <DataGridTextColumn Header="工位" Binding="{Binding Slot}" Width="60"/>
                            <DataGridTextColumn Header="Usig" Binding="{Binding UsigValue}" Width="80"/>
                            <DataGridTextColumn Header="UT" Binding="{Binding UtValue}" Width="80"/>
                            <DataGridTextColumn Header="Usource" Binding="{Binding UsourceValue}" Width="80"/>
                            <DataGridTextColumn Header="Isource" Binding="{Binding IsourceValue}" Width="*"/>
                        </DataGrid.Columns>
                    </DataGrid>

                    <Separator Margin="0,10,0,8"/>
                    <DockPanel Margin="0,0,0,8">
                        <TextBlock Text="1KHz频率测试" Style="{StaticResource GroupTitle}" Margin="0,0,8,0"/>
                        <TextBlock DockPanel.Dock="Right" Text="{Binding FrequencyStatus}"
                                   Foreground="{StaticResource MutedBrush}" VerticalAlignment="Center"/>
                    </DockPanel>
                    <Grid Margin="0,0,0,8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="90"/>
                            <ColumnDefinition Width="100"/>
                            <ColumnDefinition Width="110"/>
                            <ColumnDefinition Width="110"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Margin="0,0,6,0">
                            <TextBlock Text="工位" Style="{StaticResource Lbl}"/>
                            <TextBox Text="{Binding FrequencySlot, UpdateSourceTrigger=PropertyChanged}"/>
                        </StackPanel>
                        <StackPanel Grid.Column="1" Margin="0,0,8,0">
                            <TextBlock Text="DMM通道" Style="{StaticResource Lbl}"/>
                            <TextBox Text="{Binding FrequencyDmmChannel, UpdateSourceTrigger=PropertyChanged}"/>
                        </StackPanel>
                        <StackPanel Grid.Column="2" Margin="0,0,8,0">
                            <TextBlock Text="频率(点/秒)" Style="{StaticResource Lbl}"/>
                            <TextBox Text="{Binding FrequencyRateText, UpdateSourceTrigger=PropertyChanged}"/>
                        </StackPanel>
                        <StackPanel Grid.Column="3" Margin="0,0,8,0">
                            <TextBlock Text="停止时间(s)" Style="{StaticResource Lbl}"/>
                            <TextBox Text="{Binding FrequencyStopSecondsText, UpdateSourceTrigger=PropertyChanged}"/>
                        </StackPanel>
                        <StackPanel Grid.Column="4" Orientation="Horizontal" VerticalAlignment="Bottom">
                            <CheckBox Content="启用控制器" IsChecked="{Binding FrequencyUsePressureController}"
                                      VerticalAlignment="Center" Margin="0,0,10,6"/>
                            <Button Content="▶ 开始" Style="{StaticResource ActionButton}"
                                    Command="{Binding StartFrequencySampleCommand}" MinWidth="86"
                                    Margin="0,0,6,0"/>
                            <Button Content="⏹ 停止" Style="{StaticResource MutedActionButton}"
                                    Command="{Binding StopFrequencySampleCommand}" MinWidth="86"
                                    Margin="0,0,6,0"/>
                            <Button Content="📥 导出" Style="{StaticResource MutedActionButton}"
                                    Command="{Binding ExportFrequencyResultsCommand}" MinWidth="76"
                                    Margin="0"/>
                        </StackPanel>
                        <TextBlock Grid.Column="5" Text="{Binding FrequencySampleCount, StringFormat=点数：{0}}"
                                   Foreground="{StaticResource MutedBrush}" VerticalAlignment="Bottom"
                                   Margin="8,0,0,6"/>
                    </Grid>
                    <TextBlock Text="{Binding FrequencyAutoSavePath, StringFormat=自动保存：{0}}"
                               Foreground="{StaticResource MutedBrush}" FontSize="11"
                               TextTrimming="CharacterEllipsis" Margin="0,0,0,6"/>
                    <DataGrid ItemsSource="{Binding FrequencyResults}" AutoGenerateColumns="False"
                              BorderThickness="0" Background="{StaticResource SurfaceBrush}"
                              GridLinesVisibility="Horizontal" HeadersVisibility="Column"
                              CanUserAddRows="False" CanUserDeleteRows="False"
                              RowBackground="Transparent" AlternatingRowBackground="{StaticResource HeaderBgBrush}"
                              Padding="0" MaxHeight="160"
                              ClipboardCopyMode="IncludeHeader">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="#" Binding="{Binding Index}" Width="55"/>
                            <DataGridTextColumn Header="时间" Binding="{Binding Time}" Width="90"/>
                            <DataGridTextColumn Header="ms" Binding="{Binding ElapsedMs}" Width="80"/>
                            <DataGridTextColumn Header="工位" Binding="{Binding Slot}" Width="70"/>
                            <DataGridTextColumn Header="CH" Binding="{Binding Channel}" Width="65"/>
                            <DataGridTextColumn Header="压力" Binding="{Binding Pressure}" Width="90"/>
                            <DataGridTextColumn Header="电压mV" Binding="{Binding VoltageMv}" Width="*"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </StackPanel>
            </Border>
        </Grid>

        </StackPanel>
        </ScrollViewer>

        <!-- ════════════════════════════════════════════════════════ -->
        <!-- Row 2: 数据I/O  +  历史记录                              -->
        <!-- ════════════════════════════════════════════════════════ -->
        <Grid Grid.Row="1" Margin="0,10,0,0" MinHeight="160">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <Border Style="{StaticResource Card}" Grid.Column="0" Margin="0,0,5,0" Padding="0">
                <DockPanel>
                    <Border DockPanel.Dock="Top" Background="{StaticResource HeaderBgBrush}"
                            BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,0,0,1"
                            Padding="12,6">
                        <DockPanel>
                            <TextBlock Text="数据I/O  (TX / RX 原始报文)" FontWeight="SemiBold" VerticalAlignment="Center"/>
                            <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" HorizontalAlignment="Right">
                                <CheckBox Content="TX"   IsChecked="{Binding IoShowTx}"     Margin="6,0" VerticalAlignment="Center"
                                          Foreground="{StaticResource AccentBrush}"/>
                                <CheckBox Content="RX"   IsChecked="{Binding IoShowRx}"     Margin="6,0" VerticalAlignment="Center"
                                          Foreground="{StaticResource SuccessBrush}"/>
                                <CheckBox Content="Info" IsChecked="{Binding IoShowInfo}"   Margin="6,0" VerticalAlignment="Center"
                                          Foreground="{StaticResource MutedBrush}"/>
                                <CheckBox Content="自动滚动" IsChecked="{Binding IoAutoScroll}" Margin="12,0,6,0" VerticalAlignment="Center"/>
                                <Button Content="🗑 清空显示" Style="{StaticResource GhostButton}" Padding="8,3"
                                        Command="{Binding ClearDataIoCommand}"/>
                            </StackPanel>
                        </DockPanel>
                    </Border>
                    <TextBox x:Name="DataIoTextBox" Text="{Binding DataIoText, Mode=OneWay}"
                             BorderThickness="0" FontFamily="Consolas" FontSize="12"
                             Background="{StaticResource SurfaceBrush}"
                             IsReadOnly="True" AcceptsReturn="True" AcceptsTab="True"
                             TextWrapping="NoWrap"
                             VerticalScrollBarVisibility="Auto"
                             HorizontalScrollBarVisibility="Auto"
                             Padding="8,4"/>
                </DockPanel>
            </Border>

            <Border Style="{StaticResource Card}" Grid.Column="1" Margin="5,0,0,0" Padding="0">
                <DockPanel>
                    <Border DockPanel.Dock="Top" Background="{StaticResource HeaderBgBrush}"
                            BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,0,0,1"
                            Padding="12,6">
                        <DockPanel>
                            <TextBlock Text="历史记录  (操作动作)" FontWeight="SemiBold" VerticalAlignment="Center"/>
                            <TextBlock DockPanel.Dock="Right" Text="{Binding StatusText}"
                                       Foreground="{StaticResource MutedBrush}" HorizontalAlignment="Right"
                                       Margin="0,0,12,0" VerticalAlignment="Center"/>
                            <Button DockPanel.Dock="Right" Content="🗑 清空显示" Style="{StaticResource GhostButton}" Padding="8,3"
                                    HorizontalAlignment="Right"
                                    Command="{Binding ClearHistoryCommand}"/>
                        </DockPanel>
                    </Border>
                    <TextBox x:Name="HistoryTextBox" Text="{Binding HistoryText, Mode=OneWay}"
                             BorderThickness="0" FontFamily="Consolas" FontSize="12"
                             Background="{StaticResource SurfaceBrush}"
                             IsReadOnly="True" AcceptsReturn="True" AcceptsTab="True"
                             TextWrapping="NoWrap"
                             VerticalScrollBarVisibility="Auto"
                             HorizontalScrollBarVisibility="Auto"
                             Padding="8,4"/>
                </DockPanel>
            </Border>
        </Grid>
    </Grid>
</UserControl>
