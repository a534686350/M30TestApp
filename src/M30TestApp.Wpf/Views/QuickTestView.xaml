<UserControl x:Class="M30TestApp.Wpf.Views.QuickTestView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="clr-namespace:M30TestApp.Wpf.ViewModels"
             d:DataContext="{d:DesignInstance vm:QuickTestViewModel}"
             mc:Ignorable="d">
    <UserControl.Resources>
        <Style x:Key="SectionTitle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="15"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Margin" Value="0,0,0,8"/>
        </Style>
        <Style x:Key="FieldLabel" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{DynamicResource MutedBrush}"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Margin" Value="0,0,0,4"/>
        </Style>
        <Style x:Key="QuickResultCellStyle" TargetType="DataGridCell">
            <Setter Property="HorizontalContentAlignment" Value="Center"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Style.Triggers>
                <DataTrigger Binding="{Binding TestResult}" Value="pass">
                    <Setter Property="Background" Value="{DynamicResource SuccessBrush}"/>
                    <Setter Property="Foreground" Value="White"/>
                </DataTrigger>
                <DataTrigger Binding="{Binding TestResult}" Value="fail">
                    <Setter Property="Background" Value="{DynamicResource ErrorBrush}"/>
                    <Setter Property="Foreground" Value="White"/>
                </DataTrigger>
            </Style.Triggers>
        </Style>
        <Style x:Key="QuickFailedCellStyle" TargetType="DataGridCell">
            <Style.Triggers>
                <DataTrigger Binding="{Binding TestResult}" Value="fail">
                    <Setter Property="Foreground" Value="{DynamicResource ErrorBrush}"/>
                    <Setter Property="FontWeight" Value="SemiBold"/>
                </DataTrigger>
            </Style.Triggers>
        </Style>
    </UserControl.Resources>

    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="220"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Border Style="{StaticResource Card}" Margin="0,0,0,10">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Width="120" Margin="0,0,10,0">
                    <TextBlock Text="P0" Style="{StaticResource FieldLabel}"/>
                    <TextBox Text="{Binding P0, UpdateSourceTrigger=PropertyChanged}"/>
                </StackPanel>
                <StackPanel Grid.Column="1" Width="120" Margin="0,0,10,0">
                    <TextBlock Text="P50" Style="{StaticResource FieldLabel}"/>
                    <TextBox Text="{Binding P50, UpdateSourceTrigger=PropertyChanged}"/>
                </StackPanel>
                <StackPanel Grid.Column="2" Width="120" Margin="0,0,10,0">
                    <TextBlock Text="P100" Style="{StaticResource FieldLabel}"/>
                    <TextBox Text="{Binding P100, UpdateSourceTrigger=PropertyChanged}"/>
                </StackPanel>
                <StackPanel Grid.Column="3" Width="100" Margin="0,0,16,0">
                    <TextBlock Text="单位" Style="{StaticResource FieldLabel}"/>
                    <ComboBox ItemsSource="{Binding PressureUnits}"
                              Text="{Binding PressureUnit, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                              IsEditable="True"/>
                </StackPanel>

                <StackPanel Grid.Column="4" Width="90" Margin="0,0,10,0">
                    <TextBlock Text="压力精度" Style="{StaticResource FieldLabel}"/>
                    <TextBox Text="{Binding PressurePrecision, UpdateSourceTrigger=PropertyChanged}"/>
                </StackPanel>

                <StackPanel Grid.Column="5" Width="80" Margin="0,0,16,0">
                    <TextBlock Text="保压(s)" Style="{StaticResource FieldLabel}"/>
                    <TextBox Text="{Binding HoldSeconds, UpdateSourceTrigger=PropertyChanged}"/>
                </StackPanel>

                <StackPanel Grid.Column="6" Orientation="Horizontal" VerticalAlignment="Bottom" Margin="0,0,16,0">
                    <StackPanel Width="80" Margin="0,0,8,0">
                        <TextBlock Text="起始工位" Style="{StaticResource FieldLabel}"/>
                        <TextBox Text="{Binding StartSlot, UpdateSourceTrigger=PropertyChanged}"/>
                    </StackPanel>
                    <StackPanel Width="80">
                        <TextBlock Text="结束工位" Style="{StaticResource FieldLabel}"/>
                        <TextBox Text="{Binding EndSlot, UpdateSourceTrigger=PropertyChanged}"/>
                    </StackPanel>
                </StackPanel>

                <StackPanel Grid.Column="7" VerticalAlignment="Bottom">
                    <TextBlock Text="{Binding SensorName}" FontWeight="SemiBold"/>
                    <TextBlock Text="{Binding Status}" Foreground="{StaticResource MutedBrush}" FontSize="12" Margin="0,4,0,0"/>
                </StackPanel>

                <StackPanel Grid.Column="8" Orientation="Horizontal" VerticalAlignment="Bottom">
                    <Button Content="刷新工位" Style="{StaticResource GhostButton}" Padding="12,6"
                            Command="{Binding RefreshSlotsCommand}" Margin="0,0,8,0"/>
                    <Button Content="开始快速测试" Style="{StaticResource SaveButton}" Padding="16,6"
                            Command="{Binding StartCommand}" Margin="0,0,8,0"/>
                    <Button Content="停止" Style="{StaticResource GhostButton}" Padding="12,6"
                            Command="{Binding StopCommand}"/>
                </StackPanel>
            </Grid>
        </Border>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="260"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <Border Style="{StaticResource Card}" Margin="0,0,10,0">
                <StackPanel>
                    <TextBlock Text="压力控制器" Style="{StaticResource SectionTitle}"/>
                    <TextBlock Text="型号" Style="{StaticResource FieldLabel}"/>
                    <ComboBox ItemsSource="{Binding PressureModels}"
                              Text="{Binding PressureModel, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                              IsEditable="True"
                              Margin="0,0,0,8"/>
                    <Grid Margin="0,0,0,14">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="8"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel>
                            <TextBlock Text="端口" Style="{StaticResource FieldLabel}"/>
                            <ComboBox ItemsSource="{Binding PressurePorts}"
                                      Text="{Binding PressurePort, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                      IsEditable="True"/>
                        </StackPanel>
                        <StackPanel Grid.Column="2">
                            <TextBlock Text="地址" Style="{StaticResource FieldLabel}"/>
                            <ComboBox ItemsSource="{Binding PressureAddrs}"
                                      Text="{Binding PressureAddr, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                      IsEditable="True"/>
                        </StackPanel>
                    </Grid>

                    <TextBlock Text="判定指标" Style="{StaticResource SectionTitle}"/>
                    <TextBlock Text="测试前录入，留空表示不限。"
                               Foreground="{StaticResource MutedBrush}" TextWrapping="Wrap" Margin="0,0,0,12"/>

                    <TextBlock Text="Span Min / Max" Style="{StaticResource FieldLabel}"/>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="20"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBox Text="{Binding SpanMin, UpdateSourceTrigger=PropertyChanged}"/>
                        <TextBlock Grid.Column="1" Text="~" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        <TextBox Grid.Column="2" Text="{Binding SpanMax, UpdateSourceTrigger=PropertyChanged}"/>
                    </Grid>

                    <TextBlock Text="Linearity/NL Min / Max" Style="{StaticResource FieldLabel}" Margin="0,12,0,4"/>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="20"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBox Text="{Binding LinearityMin, UpdateSourceTrigger=PropertyChanged}"/>
                        <TextBlock Grid.Column="1" Text="~" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        <TextBox Grid.Column="2" Text="{Binding LinearityMax, UpdateSourceTrigger=PropertyChanged}"/>
                    </Grid>
                </StackPanel>
            </Border>

            <Border Grid.Column="1" Style="{StaticResource Card}" Padding="0">
                <DataGrid ItemsSource="{Binding Rows}" AutoGenerateColumns="False" IsReadOnly="True"
                          HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Auto">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="工位" Binding="{Binding Slot}" Width="80"/>
                        <DataGridTextColumn Header="序列号" Binding="{Binding SerialNo}" Width="120"/>
                        <DataGridTextColumn Header="板卡位" Binding="{Binding Board}" Width="70"/>
                        <DataGridTextColumn Header="板卡工位号" Binding="{Binding BoardSlotNo}" Width="90"/>
                        <DataGridTextColumn Header="Usig P0" Binding="{Binding P0}" Width="95"/>
                        <DataGridTextColumn Header="Usig P50" Binding="{Binding P50}" Width="95"/>
                        <DataGridTextColumn Header="Usig P100" Binding="{Binding P100}" Width="95"/>
                        <DataGridTextColumn Header="Span" Binding="{Binding Span}" Width="95"/>
                        <DataGridTextColumn Header="NL" Binding="{Binding Linearity}" Width="95"/>
                        <DataGridTextColumn Header="不合格指标" Binding="{Binding FailedMetrics}" Width="120"
                                            CellStyle="{StaticResource QuickFailedCellStyle}"/>
                        <DataGridTextColumn Header="TestResult" Binding="{Binding TestResult}" Width="100"
                                            CellStyle="{StaticResource QuickResultCellStyle}"/>
                    </DataGrid.Columns>
                </DataGrid>
            </Border>
        </Grid>

        <Border Grid.Row="2" Style="{StaticResource Card}" Padding="0" Margin="0,10,0,0">
            <DockPanel>
                <Border DockPanel.Dock="Top" Background="{StaticResource HeaderBgBrush}"
                        BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,0,0,1"
                        Padding="12,6">
                    <DockPanel>
                        <TextBlock Text="测试日志" FontWeight="SemiBold" VerticalAlignment="Center"/>
                        <TextBlock DockPanel.Dock="Right" Text="{Binding Status}"
                                   Foreground="{StaticResource MutedBrush}" VerticalAlignment="Center"/>
                    </DockPanel>
                </Border>
                <TextBox x:Name="QuickLogTextBox"
                         Text="{Binding LogText, Mode=OneWay}"
                         BorderThickness="0"
                         FontFamily="Consolas"
                         FontSize="12"
                         Background="{StaticResource SurfaceBrush}"
                         IsReadOnly="True"
                         AcceptsReturn="True"
                         AcceptsTab="True"
                         TextWrapping="NoWrap"
                         VerticalScrollBarVisibility="Auto"
                         HorizontalScrollBarVisibility="Auto"
                         Padding="8,4"
                         TextChanged="QuickLogTextBox_TextChanged"/>
            </DockPanel>
        </Border>

        <TextBlock Grid.Row="3" Text="快速测试只控制压力并采集 Usig；不执行烘箱、UT、Usource、Isource 和完整流程。"
                   Foreground="{StaticResource MutedBrush}" FontSize="12" Margin="4,8,0,0"/>
    </Grid>
</UserControl>
