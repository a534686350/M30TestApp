<UserControl x:Class="M30TestApp.Wpf.Views.TestRunView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:M30TestApp.Wpf.ViewModels"
             xmlns:views="clr-namespace:M30TestApp.Wpf.Views"
             d:DataContext="{d:DesignInstance vm:TestRunViewModel}"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d">

    <UserControl.Resources>
        <Style x:Key="KpiCard" TargetType="Border">
            <Setter Property="Background" Value="{StaticResource SurfaceBrush}"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="Padding" Value="14,10"/>
            <Setter Property="Margin" Value="0,0,10,0"/>
            <Setter Property="Effect" Value="{StaticResource CardShadow}"/>
        </Style>
        <Style x:Key="KpiLabel" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource MutedBrush}"/>
            <Setter Property="FontSize" Value="11"/>
        </Style>
        <Style x:Key="KpiValue" TargetType="TextBlock">
            <Setter Property="FontSize" Value="16"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Margin" Value="0,2,0,0"/>
            <Setter Property="TextWrapping" Value="Wrap"/>
            <Setter Property="TextTrimming" Value="CharacterEllipsis"/>
        </Style>
    </UserControl.Resources>

    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="180"/>
        </Grid.RowDefinitions>

        <!-- ────────── Row 0: KPI strip ────────── -->
        <Grid x:Name="KpiRow" Grid.Row="0" Margin="0,0,0,10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <Border Style="{StaticResource KpiCard}" Grid.Column="0">
                <StackPanel>
                    <TextBlock Text="工位总数" Style="{StaticResource KpiLabel}"/>
                    <TextBlock Text="{Binding TotalSlots}" Style="{StaticResource KpiValue}"/>
                </StackPanel>
            </Border>
            <Border Style="{StaticResource KpiCard}" Grid.Column="1">
                <StackPanel>
                    <TextBlock Text="合格" Style="{StaticResource KpiLabel}"/>
                    <TextBlock Text="{Binding OkCount}" Style="{StaticResource KpiValue}"
                               Foreground="{StaticResource SuccessBrush}"/>
                </StackPanel>
            </Border>
            <Border Style="{StaticResource KpiCard}" Grid.Column="2">
                <StackPanel>
                    <TextBlock Text="警告" Style="{StaticResource KpiLabel}"/>
                    <TextBlock Text="{Binding WarnCount}" Style="{StaticResource KpiValue}"
                               Foreground="{StaticResource WarnBrush}"/>
                </StackPanel>
            </Border>
            <Border Style="{StaticResource KpiCard}" Grid.Column="3">
                <StackPanel>
                    <TextBlock Text="异常" Style="{StaticResource KpiLabel}"/>
                    <TextBlock Text="{Binding ErrCount}" Style="{StaticResource KpiValue}"
                               Foreground="{StaticResource ErrorBrush}"/>
                </StackPanel>
            </Border>
            <Border Style="{StaticResource KpiCard}" Grid.Column="4">
                <StackPanel>
                    <TextBlock Text="温度点" Style="{StaticResource KpiLabel}"/>
                    <TextBlock Text="{Binding CurrentT}" Style="{StaticResource KpiValue}"
                               Foreground="{StaticResource AccentBrush}"/>
                </StackPanel>
            </Border>
            <Border Style="{StaticResource KpiCard}" Grid.Column="5" Margin="0">
                <StackPanel>
                    <TextBlock Text="压力点" Style="{StaticResource KpiLabel}"/>
                    <TextBlock Text="{Binding CurrentP}" Style="{StaticResource KpiValue}"
                               Foreground="{StaticResource AccentBrush}"/>
                </StackPanel>
            </Border>
        </Grid>

        <!-- ────────── Row 1: control bar ────────── -->
        <Border x:Name="ControlBar" Style="{StaticResource Card}" Grid.Row="1" Margin="0,0,0,10">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Orientation="Vertical">
                    <WrapPanel>
                        <TextBlock Text="测试类型：" Foreground="{StaticResource MutedBrush}"/>
                        <TextBlock Text="{Binding RunModeTitle}" FontWeight="SemiBold" Margin="4,0,16,0"
                                   Foreground="{StaticResource AccentBrush}"/>
                        <TextBlock Text="测试方案：" Foreground="{StaticResource MutedBrush}"/>
                        <TextBlock Text="{Binding PlanName}" FontWeight="SemiBold" Margin="4,0,16,0"/>
                        <TextBlock Text="型号：" Foreground="{StaticResource MutedBrush}"/>
                        <TextBlock Text="{Binding SensorType}" FontWeight="SemiBold" Margin="4,0,16,0"/>
                        <TextBlock Text="状态：" Foreground="{StaticResource MutedBrush}"/>
                        <TextBlock Text="{Binding Status}" FontWeight="SemiBold" Margin="4,0,16,0"/>
                        <TextBlock Text="耗时：" Foreground="{StaticResource MutedBrush}"/>
                        <TextBlock Text="{Binding Elapsed}" FontFamily="Consolas" FontWeight="SemiBold" Margin="4,0"/>
                    </WrapPanel>
                    <TextBlock Text="{Binding CurrentStep}" Foreground="{StaticResource MutedBrush}" Margin="0,4,0,0"/>
                    <TextBlock Text="{Binding LastError}" Foreground="{StaticResource ErrorBrush}" Margin="0,2,0,0"
                               TextWrapping="Wrap"/>
                </StackPanel>

                <StackPanel Orientation="Horizontal" Grid.Column="1" VerticalAlignment="Center" Margin="0,0,12,0">
                    <ProgressBar Minimum="0" Maximum="100" Value="{Binding ProgressPercentValue, Mode=OneWay}"
                                 Width="220" Height="8" Foreground="{StaticResource AccentBrush}"
                                 Background="{StaticResource HeaderBgBrush}" BorderThickness="0"/>
                    <TextBlock Margin="10,0,0,0" Foreground="{StaticResource MutedBrush}" FontFamily="Consolas">
                        <Run Text="{Binding ProgressIndex}"/> / <Run Text="{Binding ProgressTotal}"/>
                    </TextBlock>
                </StackPanel>

                <StackPanel Orientation="Horizontal" Grid.Column="2" VerticalAlignment="Center">
                    <Button Content="▶ 开始" Style="{StaticResource PrimaryButton}"
                            Command="{Binding RunCommand}" Margin="0,0,8,0"/>
                    <Button Content="{Binding PauseButtonText}" Style="{StaticResource GhostButton}"
                            Command="{Binding PauseCommand}" Margin="0,0,8,0"/>
                    <Button Content="停止" Style="{StaticResource GhostButton}"
                            Command="{Binding CancelCommand}"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- ────────── Middle: matrix + pie ────────── -->
        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="280"/>
            </Grid.ColumnDefinitions>

            <Border Style="{StaticResource Card}" Padding="0">
                <DockPanel>
                    <Border DockPanel.Dock="Top" Background="{StaticResource HeaderBgBrush}"
                            BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,0,0,1"
                            Padding="12,8">
                        <TextBlock Text="{Binding MatrixTitle}" FontWeight="SemiBold"
                                   FontSize="{StaticResource FontSizeTitle}"/>
                    </Border>
                    <views:DataMatrixGrid Rows="{Binding Rows}" Columns="{Binding Columns}"/>
                </DockPanel>
            </Border>

            <Border x:Name="StatsPanel" Style="{StaticResource Card}" Grid.Column="1" Margin="10,0,0,0">
                <StackPanel>
                    <TextBlock Text="测试统计" FontWeight="SemiBold" FontSize="{StaticResource FontSizeTitle}"
                               Margin="0,0,0,12"/>
                    <Grid Margin="0,0,0,8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <Ellipse Width="10" Height="10" Fill="{StaticResource SuccessBrush}" VerticalAlignment="Center"/>
                        <TextBlock Text="合格" Grid.Column="1" Margin="8,0"/>
                        <TextBlock Text="{Binding OkPercent}" Grid.Column="2" FontWeight="SemiBold"/>
                    </Grid>
                    <Grid Margin="0,0,0,8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <Ellipse Width="10" Height="10" Fill="{StaticResource WarnBrush}" VerticalAlignment="Center"/>
                        <TextBlock Text="警告" Grid.Column="1" Margin="8,0"/>
                        <TextBlock Text="{Binding WarnPercent}" Grid.Column="2" FontWeight="SemiBold"/>
                    </Grid>
                    <Grid Margin="0,0,0,8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <Ellipse Width="10" Height="10" Fill="{StaticResource ErrorBrush}" VerticalAlignment="Center"/>
                        <TextBlock Text="异常" Grid.Column="1" Margin="8,0"/>
                        <TextBlock Text="{Binding ErrPercent}" Grid.Column="2" FontWeight="SemiBold"/>
                    </Grid>

                    <Separator Margin="0,12"/>

                    <TextBlock Text="当前步骤" FontWeight="SemiBold" Margin="0,0,0,4"/>
                    <TextBlock Text="{Binding CurrentStep}" TextWrapping="Wrap"
                               Foreground="{StaticResource MutedBrush}"/>

                    <TextBlock Text="进度" FontWeight="SemiBold" Margin="0,12,0,4"/>
                    <ProgressBar Minimum="0" Maximum="100" Value="{Binding ProgressPercentValue, Mode=OneWay}"
                                 Height="8" Foreground="{StaticResource AccentBrush}"
                                 Background="{StaticResource HeaderBgBrush}" BorderThickness="0"/>
                    <TextBlock HorizontalAlignment="Right" Margin="0,4,0,0"
                               Foreground="{StaticResource MutedBrush}">
                        <Run Text="{Binding ProgressIndex}"/> / <Run Text="{Binding ProgressTotal}"/>
                    </TextBlock>
                </StackPanel>
            </Border>
        </Grid>

        <!-- ────────── Bottom: live log ────────── -->
        <Border Style="{StaticResource Card}" Grid.Row="3" Margin="0,10,0,0" Padding="0">
            <DockPanel>
                <Border DockPanel.Dock="Top" Background="{StaticResource HeaderBgBrush}"
                        BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,0,0,1"
                        Padding="12,6">
                    <DockPanel>
                        <TextBlock Text="实时日志" FontWeight="SemiBold" VerticalAlignment="Center"/>
                        <Button DockPanel.Dock="Right" Content="清空显示" Style="{StaticResource GhostButton}"
                                Padding="10,2" Command="{Binding ClearLogCommand}"/>
                    </DockPanel>
                </Border>
                <TextBox x:Name="LogTextBox" Text="{Binding LogText, Mode=OneWay}" BorderThickness="0"
                         FontFamily="Consolas" FontSize="12"
                         Background="{StaticResource SurfaceBrush}"
                         IsReadOnly="True" AcceptsReturn="True" AcceptsTab="True"
                         TextWrapping="NoWrap"
                         VerticalScrollBarVisibility="Auto"
                         HorizontalScrollBarVisibility="Auto"
                         Padding="10,4"
                         TextChanged="LogTextBox_TextChanged"/>
            </DockPanel>
        </Border>
    </Grid>
</UserControl>
