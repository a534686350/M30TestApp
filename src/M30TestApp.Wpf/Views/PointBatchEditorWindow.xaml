<Window x:Class="M30TestApp.Wpf.Views.PointBatchEditorWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="批量录入点表"
        Height="520"
        Width="760"
        MinHeight="420"
        MinWidth="680"
        WindowStartupLocation="CenterOwner"
        ResizeMode="CanResize">
    <Grid Margin="14">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock x:Name="HintTextBlock"
                   TextWrapping="Wrap"
                   Foreground="#334155"/>

        <DataGrid Grid.Row="1"
                  x:Name="RuleGrid"
                  ItemsSource="{Binding Rules}"
                  AutoGenerateColumns="False"
                  CanUserAddRows="True"
                  CanUserDeleteRows="True"
                  IsReadOnly="False"
                  Margin="0,12,0,12"
                  HeadersVisibility="Column"
                  GridLinesVisibility="Horizontal">
            <DataGrid.Columns>
                <DataGridTextColumn Header="范围/序号"
                                    Binding="{Binding Range, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                    Width="150"/>
                <DataGridTextColumn x:Name="ValueColumn"
                                    Header="数值"
                                    Binding="{Binding Value, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                    Width="*"/>
                <DataGridTextColumn x:Name="ExtraColumn"
                                    Header="附加"
                                    Binding="{Binding Extra, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                    Width="130"/>
                <DataGridTextColumn Header="本行点数"
                                    Binding="{Binding CountText}"
                                    IsReadOnly="True"
                                    Width="120"/>
            </DataGrid.Columns>
        </DataGrid>

        <DockPanel Grid.Row="2">
            <Button Content="取消"
                    Width="90"
                    Height="30"
                    DockPanel.Dock="Right"
                    Margin="8,0,0,0"
                    Click="Cancel_Click"/>
            <Button Content="确定"
                    Width="90"
                    Height="30"
                    DockPanel.Dock="Right"
                    Click="Ok_Click"/>
            <TextBlock Text="{Binding TotalCountText}"
                       VerticalAlignment="Center"
                       FontWeight="SemiBold"
                       Foreground="#0F766E"/>
        </DockPanel>
    </Grid>
</Window>
