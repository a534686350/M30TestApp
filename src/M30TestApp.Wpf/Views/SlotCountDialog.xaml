<Window x:Class="M30TestApp.Wpf.Views.SlotCountDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="批量生成工位"
        Width="320" Height="160" SizeToContent="Manual"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner"
        Background="{StaticResource SurfaceBrush}">
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <TextBlock Text="请输入要生成的工位数量 (1 - 256)"
                   Foreground="{StaticResource MutedBrush}" Margin="0,0,0,8"/>
        <TextBox x:Name="CountBox" Grid.Row="1" Text="32"
                 KeyDown="OnCountKeyDown" TextAlignment="Right" Padding="6,4"/>
        <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,12,0,0">
            <Button Content="取消" Width="80" Margin="0,0,8,0" IsCancel="True"/>
            <Button Content="确定" Width="80" IsDefault="True" Click="OnOk"/>
        </StackPanel>
    </Grid>
</Window>
